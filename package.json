{
  "name": "promptraise-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sanity:dev": "sanity dev",
    "sanity:dataset:production": "sanity dataset create production --visibility private --if-not-exists",
    "sanity:dataset:staging": "sanity dataset create staging --visibility private --if-not-exists"
  },
  "dependencies": {
    "@sanity/client": "^7.22.1",
    "@sanity/vision": "^5.30.0",
    "next": "16.2.7",
    "next-sanity": "^13.0.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^5.30.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
