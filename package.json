{
  "name": "promptraise-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "design:verify": "node scripts/verify-design-contract.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "figma:connect:help": "figma connect --help",
    "figma:connect:parse": "figma connect parse -c figma.config.json",
    "figma:connect:publish": "figma connect publish -c figma.config.json",
    "sanity:dev": "sanity dev",
    "sanity:dataset:production": "sanity dataset create production --visibility private --if-not-exists",
    "sanity:dataset:staging": "sanity dataset create staging --visibility private --if-not-exists"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@sanity/client": "^7.22.1",
    "@sanity/vision": "^6.0.0",
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^12.40.0",
    "next": "16.2.7",
    "next-sanity": "^13.0.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^6.0.0"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.4.8",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
