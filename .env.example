# Environment mode: production | staging
SITE_ENV=production

# Canonical site URL used by metadata routes
NEXT_PUBLIC_SITE_URL=https://www.promptraise.com

# Sanity project configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01

# Optional token for server-side mutations/previews only. Never expose client-side.
SANITY_API_READ_TOKEN=
